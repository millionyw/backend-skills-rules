  "_comment": "Copy this file to servers.json and fill in your server info. This file is gitignored.",
  "servers": {
    "<name>": {
      "host": "<IP address>",
      "user": "<SSH username>",
      "password": "<SSH password>",
      "distro": "<ubuntu|debian|openeuler|centos|rhel|linx>",
      "notes": "<optional description>"
    }
  },
  "network": {
    "subnet": "<e.g. 192.168.1.0/24>",
    "gateway": "<e.g. 192.168.1.1>",
    "dns": ["<e.g. 8.8.8.8>", "<e.g. 8.8.4.4>"]
  },
  "paths": {
    "ops_dir": "<e.g. ops>",
    "ops_rules": "<e.g. ops/AGENTS_OPS_RULES.md>"
  }
}
